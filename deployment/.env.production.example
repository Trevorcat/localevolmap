NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# 逗号分隔；若使用 * 则允许任意来源
CORS_ORIGINS=https://your-frontend.example.com,http://localhost:5173

# LocalEvomap 安全边界
ALLOWED_COMMAND_PREFIXES=node,npm,npx
FORBIDDEN_PATHS=.git,node_modules
MAX_BLAST_FILES=50
MAX_BLAST_LINES=500

# 数据路径
GENES_PATH=/opt/local-evomap/data/genes
CAPSULES_PATH=/opt/local-evomap/data/capsules
EVENTS_PATH=/opt/local-evomap/data/events
