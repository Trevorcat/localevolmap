# LocalEvomap - Production Server Configuration Example
NODE_ENV=production
HOST=0.0.0.0
PORT=3000
CORS_ORIGINS=https://your-frontend.example.com,http://localhost:5173

EVOMAP_LLM_PROVIDER=local
LLM_API_KEY=YOUR_LLM_API_KEY
LOCAL_LLM_BASE_URL=https://your-llm-endpoint.example.com/v1
EVOMAP_LLM_MODEL=gpt-5.3-codex

EVOMAP_DRY_RUN=false
EVOMAP_SESSION_SCOPE=local-dev
EVOMAP_REVIEW_MODE=true

GENES_PATH=./data/genes
CAPSULES_PATH=./data/capsules
EVENTS_PATH=./data/events

HUB_API_KEY=YOUR_API_KEY