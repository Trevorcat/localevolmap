{
  "name": "local-evomap",
  "version": "0.1.0",
  "description": "Local implementation of Capability Evolver (EvoMap) system",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsc --watch",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:remote": "bash scripts/run-playwright-remote.sh",
    "test:api": "bash scripts/test-api.sh",
    "verify:opencode": "bash scripts/verify-opencode-integration.sh",
    "test:all": "npm run test && npm run test:e2e",
    "hub:start": "npx ts-node examples/hub-server.ts",
    "example": "npx ts-node examples/use-external-capsules.ts"
  },
  "keywords": [
    "evomap",
    "capability-evolver",
    "self-evolving",
    "ai-agent",
    "gene-capsule"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "jest": "^30.2.0",
    "playwright": "^1.58.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.0.0"
  }
}
